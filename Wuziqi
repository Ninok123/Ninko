#include<stdio.h>
#include<math.h>
#include<graphics.h>
//棋子变化标记
int flag = 0;
int ChessMap[20][20] = {0};

void initGame() {
	//创建界面 宽度 高度
	initgraph(600, 500,EX_SHOWCONSOLE);
	/*
	贴图 定义变量 赋值 显示输出
	定义变量
	IMAGE img;
	加载图片
	loadimage(&img, "bg.jpg");
	贴图
	putimage(0, 0, &img);
	*/
	//加载图片中没有指定加载变量,默认加载到界面
	loadimage(NULL, "bg.jpg");
	setlinecolor(BLACK);
	//棋盘绘制
	for (int i = 0; i < 20; i++) {
		line(0, i * 25, 500, i * 25);
		line(i * 25, 0, i * 25, 500);
		line(500, 0, 500, 500);
	}
	//插入文字
	// 设置背景颜色
	setbkmode(0);
	//设置文字颜色
	settextcolor(BLACK);
	//根据坐标插入文字
	outtextxy(520, 60, "玩家1:黑棋");
	outtextxy(520, 100, "玩家2:白棋");

	
}

// 判断胜负：返回1=赢，0=没赢
int dis(int x, int y) {
	int now = ChessMap[x][y]; // 当前下的棋子颜色
	if (now == 0) return 0;

	// ============= 竖线判断（上下）=============
	int count = 1;
	// 向上
	for (int i = x - 1; i >= 1; i--) {
		if (ChessMap[i][y] == now) count++;
		else break;
	}
	// 向下
	for (int i = x + 1; i <= 19; i++) {
		if (ChessMap[i][y] == now) count++;
		else break;
	}
	if (count >= 5) return 1;

	// ============= 横线判断（左右）=============
	count = 1;
	// 向左
	for (int j = y - 1; j >= 1; j--) {
		if (ChessMap[x][j] == now) count++;
		else break;
	}
	// 向右
	for (int j = y + 1; j <= 19; j++) {
		if (ChessMap[x][j] == now) count++;
		else break;
	}
	if (count >= 5) return 1;

	// ============= 左上 -> 右下 =============
	count = 1;
	for (int i = x - 1, j = y - 1; i >= 1 && j >= 1; i--, j--) {
		if (ChessMap[i][j] == now) count++;
		else break;
	}
	for (int i = x + 1, j = y + 1; i <= 19 && j <= 19; i++, j++) {
		if (ChessMap[i][j] == now) count++;
		else break;
	}
	if (count >= 5) return 1;

	// ============= 右上 -> 左下 =============
	count = 1;
	for (int i = x - 1, j = y + 1; i >= 1 && j <= 19; i--, j++) {
		if (ChessMap[i][j] == now) count++;
		else break;
	}
	for (int i = x + 1, j = y - 1; i <= 19 && j >= 1; i++, j--) {
		if (ChessMap[i][j] == now) count++;
		else break;
	}
	if (count >= 5) return 1;

	return 0; // 没赢
}
//放置棋子
void PutChess() {
	//定义变量
	MOUSEMSG msg;
	int ChessX = 0, ChessY = 0;
	int MapX = 0, MapY = 0;//记录棋盘下标
	while (1) {

		msg = GetMouseMsg();
		/*if (msg.uMsg==WM_LBUTTONDOWN) {
			printf("x:%d,y:%d\n",msg.x,msg.y);

		}*/

		for (int i = 1; i < 20; i++) {
			for (int j = 1; j < 20; j++) {
				if (abs(msg.x - j * 25) < 12 && abs(msg.y - i * 25) < 12) {
					ChessX = j * 25;
					ChessY = i * 25;
					MapX = i;
					MapY = j;
				}
			}
		}

		if (msg.uMsg == WM_LBUTTONDOWN) {
			if (ChessMap[MapX][MapY] != 0) {
				continue;
			}
			if(flag%2==0){
				setfillcolor(BLACK);
				solidcircle(ChessX, ChessY, 10);
				ChessMap[MapX][MapY] = 1;//黑
				
			}
			else {
				setfillcolor(WHITE);
				solidcircle(ChessX, ChessY, 10);
				ChessMap[MapX][MapY] = 2;//白
			}
			//改变棋子颜色
			flag++;
		}

		if (dis(MapX,MapY)) {
			if (flag % 2==1) {
				MessageBox(NULL, "玩家1黑棋胜利", "GameOver", MB_OK);
					return ;
			}
			else {
				MessageBox(NULL, "玩家2白棋胜利", "GameOver", MB_OK);
					return;
			}
		}
	}
}

int main() {
	initGame();
	PutChess();
	getchar();
	return 0;
}
